# ========================================
# BikeVN Docker Environment Configuration
# ========================================
# Copy this file to .env and adjust values as needed
# Never commit .env file to git - add it to .gitignore

# ========================================
# MySQL Configuration
# ========================================
# Database port (default: 3306)
DB_PORT=3306

# Root password (for administrative access)
DB_ROOT_PASSWORD=root_bikevn

# Database name
DB_NAME=bikevn_db

# Regular user credentials
DB_USER=bikevn_user
DB_PASSWORD=bikevn_pass

# ========================================
# phpMyAdmin Configuration
# ========================================
# phpMyAdmin port (default: 8080)
# Access: http://localhost:8080
PHPMYADMIN_PORT=8080

# ========================================
# Adminer Configuration
# ========================================
# Adminer port (default: 8081)
# Access: http://localhost:8081
ADMINER_PORT=8081

# ========================================
# Application Environment
# ========================================
# Set to 'development', 'staging', or 'production'
APP_ENV=development

# ========================================
# Logging
# ========================================
# Set to 'true' to enable MySQL query logging
MYSQL_LOG_QUERIES=false
