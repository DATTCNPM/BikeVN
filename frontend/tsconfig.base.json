{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true, // 🌟 Luôn bật strict mode ở base để code an toàn hơn
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true, // Hữu ích trong monorepo khi cần đọc package.json
    "ignoreDeprecations": "6.0"
  }
}
